# ---------------------------------------------------------------------------
# Copy this file to .env and the application will start with these values
# AS-IS. Everything here is a SAFE PLACEHOLDER — no real credentials.
#
#   cp .env.example .env
#
#   * Change JWT_SECRET to your own long random string (anything but local dev).
#   * MAIL_* / CLOUDINARY_* are placeholders: email sending and avatar upload
#     stay disabled until you set real values, but the app boots fine without.
# ---------------------------------------------------------------------------

# --- PostgreSQL: single source of truth, shared with docker-compose ---
# DB_URL is assembled from these components, so you don't edit it by hand.
# POSTGRES_PORT=5434 matches the bundled docker "db" container's external port.
# If you connect to your OWN local PostgreSQL, set POSTGRES_PORT=5432.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=contacts
POSTGRES_HOST=localhost
POSTGRES_PORT=5434

DB_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# --- JWT (REQUIRED). Replace JWT_SECRET with your own random string. ---
JWT_SECRET=change-me-please-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_MINUTES=10080
JWT_RESET_TOKEN_EXPIRE_MINUTES=60

# --- Mail / SMTP (optional placeholders — email features stay off until set) ---
MAIL_USERNAME=example@example.com
MAIL_PASSWORD=examplePassword
MAIL_FROM=example@example.com
MAIL_PORT=465
MAIL_SERVER=smtp.example.com

# --- Cloudinary (optional placeholders — avatar upload stays off until set) ---
CLOUDINARY_NAME=
CLOUDINARY_API_KEY=0
CLOUDINARY_API_SECRET=

# --- Redis (optional; cache degrades gracefully if Redis is not running) ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_CACHE_TTL=900
